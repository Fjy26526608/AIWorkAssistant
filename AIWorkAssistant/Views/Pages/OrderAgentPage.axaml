<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:AIWorkAssistant.ViewModels"
             xmlns:ctrl="using:AIWorkAssistant.Views.Controls"
             x:Class="AIWorkAssistant.Views.Pages.OrderAgentPage"
             x:DataType="vm:OrderAgentViewModel">

    <UserControl.Resources>
        <ctrl:BytesToBitmapConverter x:Key="BytesToBitmapConverter"/>
        <ctrl:BoolToErrorColorConverter x:Key="ErrorColorConverter"/>
        <ctrl:BoolToRunningColorConverter x:Key="RunningColorConverter"/>
        <ctrl:BoolToRunningTextConverter x:Key="RunningTextConverter"/>
    </UserControl.Resources>

    <Grid Margin="16" RowDefinitions="Auto,Auto,*,Auto">

        <!-- 顶部：文件夹路径 -->
        <Border Grid.Row="0" BorderBrush="LightGray" BorderThickness="1" CornerRadius="4"
                Padding="12" Margin="0,0,0,8">
            <StackPanel Spacing="8">
                <TextBlock Text="📂 监测文件夹" FontWeight="Bold"/>
                <Grid ColumnDefinitions="*,Auto">
                    <TextBox Grid.Column="0" Text="{Binding WatchFolder}"
                             Watermark="选择或输入文件夹路径" Margin="0,0,8,0"/>
                    <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8">
                        <Button Content="启动" Command="{Binding StartCommand}"
                                IsEnabled="{Binding !IsRunning}" Width="80"/>
                        <Button Content="停止" Command="{Binding StopCommand}"
                                IsEnabled="{Binding IsRunning}" Width="80"/>
                    </StackPanel>
                </Grid>
            </StackPanel>
        </Border>

        <!-- 验证码输入区 -->
        <Border Grid.Row="1" BorderBrush="Orange" BorderThickness="2" CornerRadius="4"
                Padding="12" Margin="0,0,0,8" Background="#FFF8E1"
                IsVisible="{Binding IsCaptchaVisible}">
            <StackPanel Spacing="8">
                <TextBlock Text="🔐 请输入验证码" FontWeight="Bold" Foreground="OrangeRed"/>
                <StackPanel Orientation="Horizontal" Spacing="12" HorizontalAlignment="Center">
                    <Image Width="120" Height="40"
                           Source="{Binding CaptchaImageData, Converter={StaticResource BytesToBitmapConverter}}"/>
                    <TextBox Text="{Binding CaptchaInput}" Watermark="验证码" Width="120"
                             VerticalContentAlignment="Center"/>
                    <Button Content="确认" Command="{Binding SubmitCaptchaCommand}" Width="60"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- 日志区 -->
        <Border Grid.Row="2" BorderBrush="LightGray" BorderThickness="1" CornerRadius="4"
                Padding="8">
            <DockPanel>
                <TextBlock DockPanel.Dock="Top" Text="📋 运行日志" FontWeight="Bold" Margin="0,0,0,6"/>
                <ListBox x:Name="LogListBox" ItemsSource="{Binding Logs}"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Display}" TextWrapping="Wrap"
                                       Foreground="{Binding IsError, Converter={StaticResource ErrorColorConverter}}"/>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </DockPanel>
        </Border>

        <!-- 底部状态 -->
        <StackPanel Grid.Row="3" Orientation="Horizontal" Margin="0,8,0,0" Spacing="8">
            <Ellipse Width="10" Height="10"
                     Fill="{Binding IsRunning, Converter={StaticResource RunningColorConverter}}"/>
            <TextBlock Text="{Binding IsRunning, Converter={StaticResource RunningTextConverter}}"
                       Foreground="Gray"/>
        </StackPanel>
    </Grid>
</UserControl>
