<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:AIWorkAssistant.ViewModels"
             x:Class="AIWorkAssistant.Views.Pages.SettingsPage"
             x:DataType="vm:SettingsViewModel">

    <ScrollViewer Padding="24">
        <StackPanel Spacing="24" MaxWidth="600">
            <TextBlock Text="设置" FontSize="24" FontWeight="Bold"/>

            <!-- AI 配置 -->
            <Border BorderBrush="LightGray" BorderThickness="1" CornerRadius="8" Padding="16">
                <StackPanel Spacing="12">
                    <TextBlock Text="AI 服务配置" FontWeight="Bold" FontSize="16"/>

                    <StackPanel Spacing="4">
                        <TextBlock Text="API 地址"/>
                        <TextBox Text="{Binding ApiBaseUrl}" Watermark="https://..."/>
                    </StackPanel>

                    <StackPanel Spacing="4">
                        <TextBlock Text="API Key"/>
                        <TextBox Text="{Binding ApiKey}" PasswordChar="●" Watermark="输入 API Key"/>
                    </StackPanel>

                    <StackPanel Spacing="4">
                        <TextBlock Text="模型名称"/>
                        <TextBox Text="{Binding Model}" Watermark="模型名称"/>
                    </StackPanel>

                    <Button Content="保存 AI 配置" Command="{Binding SaveAiConfigCommand}"
                            HorizontalAlignment="Left"/>
                </StackPanel>
            </Border>

            <!-- 状态消息 -->
            <TextBlock Text="{Binding StatusMessage}" Foreground="Green"
                       IsVisible="{Binding StatusMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
        </StackPanel>
    </ScrollViewer>
</UserControl>
