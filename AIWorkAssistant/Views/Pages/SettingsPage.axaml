<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:AIWorkAssistant.ViewModels"
             x:Class="AIWorkAssistant.Views.Pages.SettingsPage"
             x:DataType="vm:SettingsViewModel">

    <ScrollViewer Padding="24">
        <StackPanel Spacing="24" MaxWidth="600">
            <TextBlock Text="设置" FontSize="24" FontWeight="Bold"/>

            <!-- AI 配置 -->
            <Border BorderBrush="LightGray" BorderThickness="1" CornerRadius="8" Padding="16">
                <StackPanel Spacing="12">
                    <TextBlock Text="AI 服务配置" FontWeight="Bold" FontSize="16"/>

                    <StackPanel Spacing="4">
                        <TextBlock Text="API 地址"/>
                        <TextBox Text="{Binding ApiBaseUrl}" Watermark="https://..."/>
                    </StackPanel>

                    <StackPanel Spacing="4">
                        <TextBlock Text="API Key"/>
                        <TextBox Text="{Binding ApiKey}" PasswordChar="●" Watermark="输入 API Key"/>
                    </StackPanel>

                    <StackPanel Spacing="4">
                        <TextBlock Text="模型名称"/>
                        <TextBox Text="{Binding Model}" Watermark="模型名称"/>
                    </StackPanel>

                    <Button Content="保存 AI 配置" Command="{Binding SaveAiConfigCommand}"
                            HorizontalAlignment="Left"/>
                </StackPanel>
            </Border>

            <!-- 用户管理（仅管理员） -->
            <Border BorderBrush="LightGray" BorderThickness="1" CornerRadius="8" Padding="16"
                    IsVisible="{Binding IsAdmin}">
                <StackPanel Spacing="12">
                    <DockPanel>
                        <TextBlock Text="用户管理" FontWeight="Bold" FontSize="16"
                                   VerticalAlignment="Center"/>
                        <Button Content="+ 添加用户" DockPanel.Dock="Right"
                                Command="{Binding AddUserCommand}"
                                HorizontalAlignment="Right"/>
                    </DockPanel>

                    <ItemsControl ItemsSource="{Binding Users}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Padding="8,4" Margin="0,2" Background="#F9F9F9"
                                        CornerRadius="4">
                                    <Grid ColumnDefinitions="*,Auto,Auto">
                                        <TextBlock Text="{Binding DisplayName}" VerticalAlignment="Center"/>
                                        <TextBlock Grid.Column="1" Text="{Binding Role}"
                                                   Foreground="Gray" Margin="8,0"
                                                   VerticalAlignment="Center"/>
                                        <TextBlock Grid.Column="2"
                                                   Text="{Binding IsEnabled, StringFormat='{}启用: {0}'}"
                                                   Foreground="Gray" VerticalAlignment="Center"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>

            <!-- 助手管理（仅管理员） -->
            <Border BorderBrush="LightGray" BorderThickness="1" CornerRadius="8" Padding="16"
                    IsVisible="{Binding IsAdmin}">
                <StackPanel Spacing="12">
                    <DockPanel>
                        <TextBlock Text="AI 助手管理" FontWeight="Bold" FontSize="16"
                                   VerticalAlignment="Center"/>
                        <Button Content="+ 添加助手" DockPanel.Dock="Right"
                                Command="{Binding AddAssistantCommand}"
                                HorizontalAlignment="Right"/>
                    </DockPanel>

                    <ItemsControl ItemsSource="{Binding Assistants}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Padding="8,4" Margin="0,2" Background="#F9F9F9"
                                        CornerRadius="4">
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <TextBlock Text="{Binding Icon}" FontSize="18"/>
                                        <TextBlock Text="{Binding Name}" VerticalAlignment="Center"/>
                                        <TextBlock Text="{Binding Description}" Foreground="Gray"
                                                   VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>

            <!-- 状态消息 -->
            <TextBlock Text="{Binding StatusMessage}" Foreground="Green"
                       IsVisible="{Binding StatusMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
        </StackPanel>
    </ScrollViewer>
</UserControl>
