<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:AIWorkAssistant.ViewModels"
             x:Class="AIWorkAssistant.Views.Pages.LoginPage"
             x:DataType="vm:LoginViewModel">

    <UserControl.KeyBindings>
        <KeyBinding Gesture="Enter" Command="{Binding LoginCommand}"/>
    </UserControl.KeyBindings>

    <Border HorizontalAlignment="Center" VerticalAlignment="Center"
            Width="360" Padding="32" CornerRadius="8"
            BorderBrush="LightGray" BorderThickness="1"
            Background="White">
        <StackPanel Spacing="16">
            <TextBlock Text="AI Work Assistant" FontSize="24" FontWeight="Bold"
                       HorizontalAlignment="Center"/>
            <TextBlock Text="企业 AI 助手平台" FontSize="14" Foreground="Gray"
                       HorizontalAlignment="Center" Margin="0,0,0,8"/>

            <TextBox x:Name="UsernameBox" Watermark="用户名"
                     Text="{Binding Username}"/>
            <TextBox Watermark="密码" PasswordChar="●"
                     Text="{Binding Password}"/>

            <TextBlock Text="{Binding ErrorMessage}" Foreground="Red"
                       IsVisible="{Binding ErrorMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                       TextWrapping="Wrap"/>

            <Button Content="登 录" HorizontalAlignment="Stretch"
                    HorizontalContentAlignment="Center"
                    Command="{Binding LoginCommand}"
                    IsEnabled="{Binding !IsLoading}"
                    Classes="accent"/>
        </StackPanel>
    </Border>
</UserControl>
