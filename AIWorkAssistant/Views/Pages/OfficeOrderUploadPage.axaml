<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:AIWorkAssistant.ViewModels"
             xmlns:ctrl="using:AIWorkAssistant.Views.Controls"
             x:Class="AIWorkAssistant.Views.Pages.OfficeOrderUploadPage"
             x:DataType="vm:OfficeOrderUploadViewModel">

    <UserControl.Resources>
        <ctrl:PathToBitmapConverter x:Key="PathToBitmapConverter"/>
        <ctrl:BoolToErrorColorConverter x:Key="ErrorColorConverter"/>
    </UserControl.Resources>

    <Grid RowDefinitions="Auto,*,Auto" Margin="16">
        <TextBlock Grid.Row="0" Text="订单自动上传" FontSize="22" FontWeight="Bold" Margin="0,0,0,12"/>

        <Grid Grid.Row="1" ColumnDefinitions="430,*" ColumnSpacing="16">
            <ScrollViewer Grid.Column="0">
                <StackPanel Spacing="12">
                    <Border BorderBrush="LightGray" BorderThickness="1" CornerRadius="8" Padding="12">
                        <StackPanel Spacing="8">
                            <TextBlock Text="订单文件夹" FontWeight="Bold"/>
                            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                                <TextBox Grid.Column="0"
                                         Text="{Binding OrderFolderPath}"
                                         Watermark="选择包含 .doc/.docx 订单的文件夹"/>
                                <Button Grid.Column="1"
                                        Content="选择文件夹"
                                        Click="BrowseFolderButton_Click"/>
                            </Grid>
                            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                                <TextBox Grid.Column="0"
                                         Text="{Binding ScanIntervalMinutes}"
                                         Watermark="扫描间隔（分钟）"/>
                                <TextBlock Grid.Column="1"
                                           Text="默认 10 分钟"
                                           Foreground="Gray"
                                           VerticalAlignment="Center"/>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <Border BorderBrush="LightGray" BorderThickness="1" CornerRadius="8" Padding="12">
                        <StackPanel Spacing="8">
                            <TextBlock Text="订单系统配置" FontWeight="Bold"/>
                            <TextBox Text="{Binding TargetUrl}" Watermark="登录网址"/>
                            <TextBox Text="{Binding OrderPageUrl}" Watermark="新增订单页面地址"/>
                            <Grid ColumnDefinitions="*,*" ColumnSpacing="8">
                                <TextBox Grid.Column="0" Text="{Binding Username}" Watermark="账号"/>
                                <TextBox Grid.Column="1" Text="{Binding Password}" PasswordChar="●" Watermark="密码"/>
                            </Grid>
                            <Grid ColumnDefinitions="*,*" ColumnSpacing="8">
                                <TextBox Grid.Column="0" Text="{Binding SaleType}" Watermark="销售类型，如 煤矿"/>
                                <TextBox Grid.Column="1" Text="{Binding MoneyType}" Watermark="币种，如 人民币"/>
                            </Grid>
                            <Grid ColumnDefinitions="*,*" ColumnSpacing="8">
                                <TextBox Grid.Column="0" Text="{Binding Rate}" Watermark="汇率，如 1"/>
                                <TextBox Grid.Column="1" Text="{Binding MarketType}" Watermark="新老市场，如 老市场"/>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <Button Content="保存配置" Command="{Binding SaveSettingsCommand}" Width="100"/>
                        <Button Content="开始监听"
                                Command="{Binding StartCommand}"
                                IsEnabled="{Binding !IsRunning}"
                                Width="100"
                                Classes="accent"/>
                        <Button Content="停止" Command="{Binding StopCommand}" IsEnabled="{Binding IsRunning}" Width="80"/>
                    </StackPanel>

                    <ProgressBar Minimum="0" Maximum="100" Value="{Binding ProgressValue}" IsVisible="{Binding IsRunning}"/>
                    <TextBlock Text="{Binding ProgressText}" Foreground="Gray" TextWrapping="Wrap"/>
                    <TextBlock Text="{Binding StatusMessage}" TextWrapping="Wrap"/>

                    <Grid ColumnDefinitions="Auto,*" RowDefinitions="Auto,Auto,Auto" ColumnSpacing="8" RowSpacing="4">
                        <TextBlock Grid.Row="0" Grid.Column="0" Text="上次扫描" Foreground="Gray"/>
                        <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding LastScanTime}" TextWrapping="Wrap"/>
                        <TextBlock Grid.Row="1" Grid.Column="0" Text="下次扫描" Foreground="Gray"/>
                        <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding NextScanTime}" TextWrapping="Wrap"/>
                        <TextBlock Grid.Row="2" Grid.Column="0" Text="累计解析" Foreground="Gray"/>
                        <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding ParsedFileCount}"/>
                    </Grid>
                </StackPanel>
            </ScrollViewer>

            <Border Grid.Column="1" BorderBrush="LightGray" BorderThickness="1" CornerRadius="8" Padding="8">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top" Text="运行日志" FontWeight="Bold" Margin="0,0,0,6"/>
                    <ScrollViewer x:Name="LogScrollViewer" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto">
                        <TextBox x:Name="LogTextBox"
                                 Text="{Binding LogText}"
                                 IsReadOnly="True"
                                 AcceptsReturn="True"
                                 TextWrapping="Wrap"
                                 FontFamily="Consolas"
                                 BorderThickness="0"/>
                    </ScrollViewer>
                </DockPanel>
            </Border>
        </Grid>

        <TextBlock Grid.Row="2"
                   Text="监听启动后会立即扫描一次，之后按设置的间隔扫描。每个订单会输出 .doc.txt、.ai.raw.json、.ai.cleaned.json 和可用于上传的 .ai.json。"
                   Foreground="Gray"
                   Margin="0,10,0,0"
                   TextWrapping="Wrap"/>

        <Border Grid.RowSpan="3"
                Background="#99000000"
                IsVisible="{Binding IsCaptchaVisible}">
            <Border Width="420"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Background="White"
                    BorderBrush="#F59E0B"
                    BorderThickness="2"
                    CornerRadius="8"
                    Padding="18">
                <StackPanel Spacing="12">
                    <TextBlock Text="请输入验证码"
                               FontSize="18"
                               FontWeight="Bold"
                               Foreground="#B45309"/>
                    <Image Source="{Binding CaptchaImagePath, Converter={StaticResource PathToBitmapConverter}}"
                           Width="180"
                           Height="60"
                           Stretch="Uniform"
                           HorizontalAlignment="Center"/>
                    <TextBox Text="{Binding CaptchaInput}"
                             Watermark="验证码"
                             FontSize="18"
                             HorizontalContentAlignment="Center">
                        <TextBox.KeyBindings>
                            <KeyBinding Gesture="Enter"
                                        Command="{Binding SubmitCaptchaCommand}"/>
                        </TextBox.KeyBindings>
                    </TextBox>
                    <StackPanel Orientation="Horizontal"
                                Spacing="8"
                                HorizontalAlignment="Right">
                        <Button Content="取消"
                                Command="{Binding CancelCaptchaCommand}"
                                Width="80"/>
                        <Button Content="确认"
                                Command="{Binding SubmitCaptchaCommand}"
                                Width="80"
                                Classes="accent"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Border>

        <Border Grid.RowSpan="3"
                Background="#99000000"
                IsVisible="{Binding IsConfirmVisible}">
            <Border Width="980"
                    MaxHeight="820"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Background="White"
                    BorderBrush="#3B82F6"
                    BorderThickness="2"
                    CornerRadius="8"
                    Padding="18">
                <Grid RowDefinitions="Auto,*,Auto" RowSpacing="12">
                    <TextBlock Grid.Row="0"
                               Text="请检查订单预览，确认后提交"
                               FontSize="18"
                               FontWeight="Bold"/>
                    <ScrollViewer Grid.Row="1"
                                  VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Auto">
                        <Image Source="{Binding PreviewImagePath, Converter={StaticResource PathToBitmapConverter}}"
                               Stretch="Uniform"/>
                    </ScrollViewer>
                    <StackPanel Grid.Row="2"
                                Orientation="Horizontal"
                                Spacing="8"
                                HorizontalAlignment="Right">
                        <Button Content="跳过"
                                Command="{Binding SkipSubmitCommand}"
                                Width="90"/>
                        <Button Content="提交"
                                Command="{Binding ConfirmSubmitCommand}"
                                Width="90"
                                Classes="accent"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Border>
    </Grid>
</UserControl>
